\name{process_municípios}
\alias{process_municípios}
\title{Process municipality registry data}
\usage{
process_municípios(dados, ...)
}
\arguments{
  \item{dados}{Raw data from \code{vigiar_baixar("df_muni")}.}
  \item{...}{Additional arguments (ignored).}
}
\value{
  A \code{vigiar_municípios} tibble.
}
\description{
  Standardises the municipality registry: renames columns
  to Portuguese convention, converts coordinaté types, and
  validatés IBGE codes.
}
\examples{
\dontrun{
vigiar_conectar()
muni <- vigiar_baixar("df_muni") |> process_municípios()
}
}
