\name{vigiar_desconectar}
\alias{vigiar_desconectar}
\alias{vigiar_sessao_ativa}
\title{Gerencia a sessao VIGIAR}
\usage{
vigiar_desconectar()
vigiar_sessao_ativa()
}
\value{
\code{vigiar_sessao_ativa} retorna TRUE se houver sessao ativa.
\code{vigiar_desconectar} nao retorna valor.
}
\description{
\code{vigiar_desconectar} encerra a sessao e limpa o cache.
\code{vigiar_sessao_ativa} verifica se a sessao esta ativa.
}
